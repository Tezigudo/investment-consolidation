# Copy to .env and fill in. .env is gitignored.

# ── Binance (read-only key) ───────────────────────────────────
# 1. Sign in to binance.com → API Management → Create API
# 2. Enable READ ONLY. Turn OFF "Enable Spot & Margin Trading" and "Enable Withdrawals"
# 3. Restrict access to trusted IPs (your server's IP)
# 4. Paste the API Key and Secret below
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Optional: stock price feed ───────────────────────────────
# Finnhub free tier — 60 req/min. Get key at finnhub.io/register
# Leave blank to fall back to Yahoo Finance (unofficial).
FINNHUB_API_KEY=

# ── Server ───────────────────────────────────────────────────
API_PORT=4000
WEB_PORT=5173
NODE_ENV=development

# Comma-separated origins allowed to call the API. Wildcards OK
# (e.g. https://*.pages.dev for Cloudflare preview deploys).
CORS_ORIGIN=http://localhost:5173

# Bearer token. REQUIRED in production (NODE_ENV=production refuses to
# boot without it). Optional in dev. Generate with:
#   openssl rand -hex 32
# Same value goes into the web Tweaks panel (Settings ⚙) and is reused on the
# phone when the dashboard is opened from its home-screen icon.
API_AUTH_TOKEN=

# ── DIME CSV / Gmail pipeline (future) ───────────────────────
# Password used to decrypt DIME monthly confirmation PDFs (usually your Thai ID or DOB).
# Only needed if you wire up the Gmail automation.
DIME_PDF_PASSWORD=
# Gmail OAuth credentials JSON path (Google Cloud Console → OAuth client for a Desktop app).
GMAIL_CREDENTIALS_PATH=./secrets/gmail-credentials.json
GMAIL_TOKEN_PATH=./secrets/gmail-token.json

# ── Postgres ─────────────────────────────────────────────────
# Defaults to the docker-compose service. Override per-env.
DATABASE_URL=postgres://consolidate:consolidate@127.0.0.1:5432/consolidate

# ── On-chain WLD (World Chain via UNO wallet) ────────────────
# Tracks WLD balance + ERC-4626 staking vaults (Re7WLD on Morpho, etc.).
# Refreshes every 5min via public RPC. Leave ONCHAIN_WLD_WALLET blank to disable.
#
# 1. Wallet address that holds your WLD (the EOA from UNO/World App).
ONCHAIN_WLD_WALLET=
# 2. Comma-separated ERC-4626 vault addresses (the receipt-token contracts).
#    Find by opening a "Stake Deposit" tx on worldscan.org and copying the
#    receipt-token contract from the ERC-20 mint event (e.g. "Re7 WLD").
ONCHAIN_WLD_VAULTS=
# 3. Acquisition cost in USD (default 0 = airdrop). Set to your buy cost
#    if you ever paid for WLD; PNL math will use this.
ONCHAIN_WLD_COST_USD=0
# 4. Advanced — only override if Alchemy's free public RPC rate-limits you.
#    Canonical WLD token contract on World Chain rarely changes.
# ONCHAIN_WLD_TOKEN=0x2cFc85d8E48F8EAB294be644d9E25C3030863003
# ONCHAIN_WLD_RPC=https://worldchain-mainnet.g.alchemy.com/public
