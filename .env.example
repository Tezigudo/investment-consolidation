# Copy to .env and fill in. .env is gitignored.

# ── Binance (read-only key) ───────────────────────────────────
# 1. Sign in to binance.com → API Management → Create API
# 2. Enable READ ONLY. Turn OFF "Enable Spot & Margin Trading" and "Enable Withdrawals"
# 3. Restrict access to trusted IPs (your server's IP)
# 4. Paste the API Key and Secret below
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Optional: stock price feed ───────────────────────────────
# Finnhub free tier — 60 req/min. Get key at finnhub.io/register
# Leave blank to fall back to Yahoo Finance (unofficial).
FINNHUB_API_KEY=

# ── Server ───────────────────────────────────────────────────
API_PORT=4000
WEB_PORT=5173
NODE_ENV=development

# Comma-separated origins allowed to call the API (frontend dev URL goes here)
CORS_ORIGIN=http://localhost:5173

# ── DIME CSV / Gmail pipeline (future) ───────────────────────
# Password used to decrypt DIME monthly confirmation PDFs (usually your Thai ID or DOB).
# Only needed if you wire up the Gmail automation.
DIME_PDF_PASSWORD=
# Gmail OAuth credentials JSON path (Google Cloud Console → OAuth client for a Desktop app).
GMAIL_CREDENTIALS_PATH=./secrets/gmail-credentials.json
GMAIL_TOKEN_PATH=./secrets/gmail-token.json
