{
  "expo": {
    "name": "Consolidate",
    "slug": "consolidate-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "consolidate",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0b0d11"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tezigudo.consolidate",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock Consolidate with Face ID to view your portfolio.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-local-authentication"
    ],
    "experiments": {
      "tsconfigPaths": true
    }
  }
}
