# Web build-time env vars (Vite). Set in Cloudflare Pages dashboard
# (Settings → Environment variables) for production builds.
#
# Optional — if you set this, the deployed bundle will hit the URL
# directly. If you leave it blank, the user can paste the URL into
# the in-app Settings popover (⚙) at runtime. Either works.
VITE_API_URL=https://consolidate-api.fly.dev
